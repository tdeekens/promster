{
  "name": "@promster/apollo",
  "version": "15.5.2",
  "description": "Apollo server integrations of promster",
  "keywords": [
    "continousdelivery",
    "metrics",
    "prometheus"
  ],
  "homepage": "https://github.com/tdeekens/promster#readme",
  "bugs": {
    "url": "https://github.com/tdeekens/promster/issues"
  },
  "license": "MIT",
  "author": "Tobias Deekens <nerd@tdeekens.name>",
  "repository": {
    "type": "git",
    "url": "https://github.com/tdeekens/promster.git",
    "directory": "packages/apollo"
  },
  "files": [
    "readme.md",
    "package.json",
    "LICENSE",
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@apollo/server": "5.5.1",
    "@promster/metrics": "workspace:*",
    "merge-options": "3.0.4",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@graphql-tools/schema": "10.0.33",
    "@graphql-tools/utils": "11.1.0",
    "@promster/server": "workspace:*",
    "@promster/tsconfig": "workspace:*",
    "@promster/tsdown-config": "workspace:*",
    "@promster/types": "workspace:*",
    "graphql": "16.13.2",
    "graphql-tag": "2.12.7",
    "parse-prometheus-text-format": "1.1.1",
    "tsdown": "0.22.2"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=8"
  }
}
