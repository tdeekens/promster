{
  "name": "@promster/undici",
  "version": "15.5.1",
  "description": "Undici server integrations of promster",
  "keywords": [
    "continousdelivery",
    "metrics",
    "prometheus",
    "undici"
  ],
  "homepage": "https://github.com/tdeekens/promster#readme",
  "bugs": {
    "url": "https://github.com/tdeekens/promster/issues"
  },
  "license": "MIT",
  "author": "Tobias Deekens <nerd@tdeekens.name>",
  "repository": {
    "type": "git",
    "url": "https://github.com/tdeekens/promster.git",
    "directory": "packages/undici"
  },
  "files": [
    "readme.md",
    "package.json",
    "LICENSE",
    "dist/**"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "typesVersions": {
    "*": {
      ".": [
        "dist/*.d.ts",
        "dist/*.d.cts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsup",
    "check-types": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "dev": "tsup --watch --clean=false"
  },
  "dependencies": {
    "@promster/metrics": "workspace:*",
    "merge-options": "3.0.4",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@promster/express": "workspace:*",
    "@promster/server": "workspace:*",
    "@promster/tsconfig": "workspace:*",
    "@promster/types": "workspace:*",
    "@types/node": "24.12.2",
    "express": "5.2.1",
    "parse-prometheus-text-format": "1.1.1",
    "prom-client": "15.1.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "undici": "8.1.0"
  },
  "peerDependencies": {
    "prom-client": "13.x.x || 14.x || 15.x",
    "undici": "7.x.x || 8.x"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  }
}
