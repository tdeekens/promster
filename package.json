{
  "name": "promster",
  "private": true,
  "description": "Monorepository for promster and its projects e.g. metrics, hapi and express",
  "keywords": [
    "continousdelivery",
    "devops",
    "metrics",
    "monitoring",
    "prometheus"
  ],
  "homepage": "https://github.com/tdeekens/promster#readme",
  "bugs": {
    "url": "https://github.com/tdeekens/promster/issues"
  },
  "author": "Tobias Deekens <nerd@tdeekens.name>",
  "scripts": {
    "auth": "npm_config_registry=https://registry.npmjs.org npm whoami",
    "build:watch": "turbo watch build",
    "build": "turbo build",
    "dev": "turbo dev",
    "changeset:version-and-format": "changeset version && pnpm format && pnpm install --no-frozen-lockfile",
    "changeset": "changeset",
    "check-types": "turbo check-types",
    "check-exports": "pnpm --filter \"./packages/*\" exec attw --pack .",
    "clean": "manypkg exec rm -rf dist .turbo && rm -rf .turbo",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prerelease": "pnpm auth && pnpm build",
    "release": "changeset publish",
    "setup": "husky install && manypkg check && check-node-version --package --print",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --reporter=junit --outputFile=junit.xml",
    "test": "turbo test"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-typescript": "8.0.1",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@manypkg/cli": "0.25.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.3",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.10",
    "check-node-version": "4.2.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "turbo": "2.10.5",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=22",
    "npm": ">=11",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.9.0"
}
