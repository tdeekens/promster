{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "strict": true,
    "composite": true,
    "types": ["node"],
    "typeRoots": ["@types", "@types-extensions", "node_modules/@types"],
    "lib": ["ESNext"]
  },
  "exclude": ["**/ts-build-cache/**/*", "packages/**/dist/*"]
}
